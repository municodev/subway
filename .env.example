# Subway Configuration
# Copy this file to .env and fill in your values.

# ---- Embedding ----
# Provider: ollama (local) or openai (remote API)
# SUBWAY_EMBED_PROVIDER=ollama

# Model: nomic-embed-text, text-embedding-3-small, etc.
# SUBWAY_EMBED_MODEL=nomic-embed-text:latest

# API Key (required for openai, ignored for ollama)
# Also reads OPENAI_API_KEY as fallback for both embed and narrate
# SUBWAY_EMBED_API_KEY=sk-...
# SUBWAY_EMBED_BASE_URL=http://localhost:11434

# ---- Narration (LLM) ----
# Provider: ollama (local) or openai (remote API)
# SUBWAY_NARRATE_PROVIDER=ollama

# Model: llama3.2, gpt-4o-mini, etc.
# SUBWAY_NARRATE_MODEL=llama3.2:latest

# API Key (required for openai, ignored for ollama)
# SUBWAY_NARRATE_API_KEY=sk-...
# SUBWAY_NARRATE_BASE_URL=http://localhost:11434
