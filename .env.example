# Subway Embedding Configuration
# Copy this file to .env and fill in your values.

# Provider: ollama (local) or openai (remote API)
# SUBWAY_EMBED_PROVIDER=ollama

# Model name
# Ollama: nomic-embed-text:latest
# OpenAI: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
# SUBWAY_EMBED_MODEL=nomic-embed-text:latest

# API Key (required for openai, ignored for ollama)
# Also reads OPENAI_API_KEY as fallback
# SUBWAY_EMBED_API_KEY=sk-...

# Base URL (override for self-hosted or Azure)
# SUBWAY_EMBED_BASE_URL=http://localhost:11434
# SUBWAY_EMBED_BASE_URL=https://api.openai.com
